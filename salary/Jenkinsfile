pipeline {
    agent any
    
    environment {
        // Explicitly defining the Java home path to avoid terminal environment mismatch
        JAVA_HOME = '/usr/lib/jvm/java-21-openjdk' // Standard path, adjust if your machine uses a different directory
        PATH      = "${env.JAVA_HOME}/bin:${env.PATH}"
    }
    
    tools {
        maven '3.8.7' 
        jdk 'Java 21' 
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Compile') {
            steps {
                // Navigate into your sub-repository directory before running Maven
                dir('salary') {
                    sh 'mvn clean compile'
                }
            }
        }

        stage('Run Tests') {
            parallel {
                stage('Unit Tests') {
                    steps {
                        dir('salary') {
                            catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                                sh 'mvn test'
                            }
                        }
                    }
                }
                stage('Integration & E2E Tests') {
                    steps {
                        dir('salary') {
                            catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                                sh 'mvn verify -DskipUTs=true'
                            }
                        }
                    }
                }
            }
        }

        stage('Generate PDF Reports') {
            steps {
                dir('salary') {
                    catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                        echo "Generating PDF test reports..."
                        sh 'mvn pdf:pdf' 
                    }
                }
            }
        }
    }

    post {
        always {
            // Updated paths to look inside the 'salary' directory for reports
            junit allowEmptyResults: true, testResults: 'salary/target/surefire-reports/*.xml,salary/target/failsafe-reports/*.xml'
            
            recordCoverage(
                tools: [[parser: 'JACOCO', pattern: 'salary/target/site/jacoco/jacoco.xml']],
                sourceCodeRetention: 'EVERY_BUILD'
            )
            
            archiveArtifacts artifacts: 'salary/target/*.pdf, salary/target/site/jacoco/**', allowEmptyArchive: true
        }
        failure {
            echo "Pipeline failed. Check test thresholds or compilation errors."
        }
    }
}
