@Library('my-shared-library') _

import org.company.DeploymentManager

pipeline {
    agent any
    
    parameters {
        choice(name: 'DEPLOY_ENV', choices: ['dev', 'staging', 'prod'], description: 'Select target environment')
    }

    options {
        timeout(time: 1, unit: 'HOURS')
        ansiColor('xterm')
    }

    stages {
        stage('Initialize & Notify') {
            steps {
                script {
                    // Send an initial notification to tracking systems
                    echo "🔔 Notification: Build #${BUILD_NUMBER} Started for branch ${env.BRANCH_NAME ?: 'master'}"
                    // Slack call placeholder: slackSend(channel: '#deployments', color: '#FFFF00', message: "STARTED: Job '${env.JOB_NAME}' [Build #${env.BUILD_NUMBER}]")
                }
            }
        }

        stage('Checkout & Build') {
            steps {
                git url: 'https://github.com/tekhoney/OT-Microservices.git', branch: 'master'
                echo "Building Attendance Microservice Image..."
            }
        }
        
        stage('Execute Core Deployment Actions') {
            steps {
                script {
                    def deployer = new DeploymentManager(this, params.DEPLOY_ENV)
                    
                    try {
                        deployer.validate()
                        deployer.deploy()
                        
                        
                        
                    } catch (Exception e) {
                        echo "⚠️ Deployment Intercepted an Error: ${e.message}"
                        currentBuild.result = 'FAILURE'
                        
                        // Execute your active container recovery logic
                        deployer.rollback()
                    }
                }
            }
        }
    }

    // ASSIGNMENT 02 - FULLY COMPLIANT DECLARATIVE POST ACTIONS BLOCK
    post {
        always {
            script {
                // 1. Gather build details (duration, changes) dynamically
                echo "📊 Build Finished. Duration: ${currentBuild.durationString}. Status: ${currentBuild.currentResult}"
                
                // Collect commit logs/changes safely
                def changeLogSets = currentBuild.changeSets
                if (changeLogSets.size() > 0) {
                    echo "📋 Build Changes Detected:"
                    for (int i = 0; i < changeLogSets.size(); i++) {
                        def entries = changeLogSets[i].items
                        for (int j = 0; j < entries.length; j++) {
                            echo "- ${entries[j].msg} by ${entries[j].author.fullName}"
                        }
                    }
                } else {
                    echo "📋 No new changes detected in this build execution."
                }
            }
        }
        
        success {
            script {
                // 2. Handle notification failures gracefully using try-catch blocks
                try {
                    // 3. Conditional evaluation (We fall back to checking Git environment data safely)
                    def runBranch = env.BRANCH_NAME ?: 'master'
                    
                    echo "✅ Processing Success Notifications for branch: ${runBranch}"
                    
                    // Live Slack Notification with explicit build details (Duration, Environment)
                    slackSend channel: '#jenkins-alerts', 
                              color: 'good', 
                              message: "✅ SUCCESSFUL: Job '${env.JOB_NAME}' [Build #${env.BUILD_NUMBER}]\n• *Branch:* ${runBranch}\n• *Duration:* ${currentBuild.durationString}\n• *Environment:* ${params.DEPLOY_ENV.toUpperCase()}"
                    
                    // Custom success email template implementation
                    String successEmailBody = """
                        <h3>✅ Jenkins Deployment Successful Notification</h3>
                        <p><b>Job:</b> ${env.JOB_NAME}</p>
                        <p><b>Build Number:</b> #${env.BUILD_NUMBER}</p>
                        <p><b>Branch:</b> ${runBranch}</p>
                        <p><b>Target Deployment:</b> ${params.DEPLOY_ENV.toUpperCase()}</p>
                        <p><b>Duration:</b> ${currentBuild.durationString}</p>
                        <p><b>Console Link:</b> <a href="${env.BUILD_URL}console">${env.BUILD_URL}console</a></p>
                        <p><i>Status: All deployment routines and sanity validations passed seamlessly.</i></p>
                    """
                    
                    emailext body: successEmailBody, 
                             mimeType: 'text/html', 
                             subject: "DEPL_SUCCESS: ${env.JOB_NAME} - Build #${env.BUILD_NUMBER} OK", 
                             to: 'itkrishan21@gmail.com'
                             
                } catch (Exception notifyError) {
                    // Graceful handling of notification infrastructure breakdowns
                    echo "⚠️ Success Notification Engine Intercepted an Error: ${notifyError.message}"
                }
            }
        }

        failure {
            script {
                try {
                    def runBranch = env.BRANCH_NAME ?: 'master'
                    echo "🚨 CRITICAL: Build #${BUILD_NUMBER} Failed on branch: ${runBranch}. Dispatching failure alerts..."
                    
                    String failureEmailBody = """
                        <h3>❌ Jenkins Build Deployment Failure Notification</h3>
                        <p><b>Job:</b> ${env.JOB_NAME}</p>
                        <p><b>Build Number:</b> #${env.BUILD_NUMBER}</p>
                        <p><b>Branch:</b> ${runBranch}</p>
                        <p><b>Target Deployment:</b> ${params.DEPLOY_ENV.toUpperCase()}</p>
                        <p><b>Duration:</b> ${currentBuild.durationString}</p>
                        <p><b>Console Logs Link:</b> <a href="${env.BUILD_URL}console">${env.BUILD_URL}console</a></p>
                        <p><i>Note: Active container rollback actions were executed automatically. Check host container status.</i></p>
                    """
                    
                    // Live Failure Slack alert with detailed message parameters
                    slackSend channel: '#jenkins-alerts', 
                              color: 'danger', 
                              message: "🚨 CRITICAL FAILURE: Job '${env.JOB_NAME}' [Build #${env.BUILD_NUMBER}] failed!\n• *Branch:* ${runBranch}\n• *Duration:* ${currentBuild.durationString}\n• *Action Taken:* Active automated container rollback executed."
                    
                    // Live Failure custom Email Template implementation
                    emailext body: failureEmailBody, 
                             mimeType: 'text/html', 
                             subject: "DEPL_ALERT: ${env.JOB_NAME} - Build #${env.BUILD_NUMBER} FAILURE", 
                             to: 'itkrishan21@gmail.com'
                             
                } catch (Exception notifyError) {
                    echo "⚠️ Failure Notification System Encountered an Error: ${notifyError.message}. Moving forward gracefully."
                }
            }
        }

        unstable {
            script {
                try {
                    slackSend channel: '#jenkins-alerts', 
                              color: 'warning', 
                              message: "⚠️ UNSTABLE: Job '${env.JOB_NAME}' [Build #${env.BUILD_NUMBER}] marked as unstable. Check automation verification matrices."
                } catch (Exception notifyError) {
                    echo "⚠️ Unstable Notification System Encountered an Error: ${notifyError.message}"
                }
            }
        }
    }
