@Library('my-shared-library') _

import org.company.DeploymentManager

pipeline {
    agent any
    
    parameters {
        choice(name: 'DEPLOY_ENV', choices: ['dev', 'staging', 'prod'], description: 'Select target environment')
    }

    options {
        timeout(time: 1, unit: 'HOURS')
        ansiColor('xterm')
    }

    stages {
        stage('Initialize & Notify') {
            steps {
                script {
                    echo "🔔 Notification: Build #${BUILD_NUMBER} Started for branch ${env.BRANCH_NAME ?: 'master'}"
                }
            }
        }

        stage('Checkout & Build') {
            steps {
                git url: 'https://github.com/tekhoney/OT-Microservices.git', branch: 'master'
                echo "Building Attendance Microservice Image..."
            }
        }
        
        stage('Execute Core Deployment Actions') {
            steps {
                script {
                    def deployer = new DeploymentManager(this, params.DEPLOY_ENV)
                    
                    try {
                        deployer.validate()
                        deployer.deploy()
                        
                        // FORCE FAILURE TO RUN DEBUG POST BLOCK ACTIONS
                        error "Simulated Deployment Timeout"
                        
                    } catch (Exception e) {
                        echo "⚠️ Deployment Intercepted an Error: ${e.message}"
                        currentBuild.result = 'FAILURE'
                        deployer.rollback()
                        throw e
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                echo "📊 Build Finished. Duration: ${currentBuild.durationString}. Status: ${currentBuild.currentResult}"
            }
        }
        
        success {
            script {
                echo "✅ Processing Success State Actions."
            }
        }

        failure {
            script {
                echo "🚨 DEBUG ENGINE STARTING: Initiating dual-routing email diagnostics..."
                
                // -------------------------------------------------------------
                // DIAGNOSTIC ROUTE A: EXTENDED EMAIL PLUGIN
                // -------------------------------------------------------------
                try {
                    echo "📨 Attempting Diagnostic Route A (emailext)..."
                    String failureEmailBody = "<h3>❌ Jenkins Build #${env.BUILD_NUMBER} Failure</h3>"
                    
                    emailext body: failureEmailBody, 
                             mimeType: 'text/html', 
                             subject: "DEPL_ALERT: ${env.JOB_NAME} - Build #${env.BUILD_NUMBER} FAILURE", 
                             to: 'itkrishan21@gmail.com',
                             from: 'itkrishan21@gmail.com',
                             replyTo: 'itkrishan21@gmail.com',
                             attachLog: true,
                             recipientProviders: [[$class: 'DevelopersRecipientProvider'], [$class: 'RequesterRecipientProvider']]
                             
                    echo "✔️ Diagnostic Route A (emailext) completed successfully without script exceptions."
                } catch (Exception notifyError) {
                    echo "❌ Diagnostic Route A CRASHED with error: ${notifyError.message}"
                }
                
                // -------------------------------------------------------------
                // DIAGNOSTIC ROUTE B: NATIVE JENKINS BASIC MAIL (Bypasses Extended Plugin Settings)
                // -------------------------------------------------------------
                try {
                    echo "📨 Attempting Diagnostic Route B (Native basic mail)..."
                    
                    mail body: "Your Jenkins job ${env.JOB_NAME} Build #${env.BUILD_NUMBER} failed. Access the pipeline interface to review terminal stacktraces.",
                         subject: "ALERT: Jenkins Build #${env.BUILD_NUMBER} Failed (Native Step)",
                         to: 'itkrishan21@gmail.com'
                         
                    echo "✔️ Diagnostic Route B (Native basic mail) executed successfully."
                } catch (Exception nativeError) {
                    echo "❌ Diagnostic Route B CRASHED with error: ${nativeError.message}"
                }

                // -------------------------------------------------------------
                // SLACK DISPATCH ROUTINE
                // -------------------------------------------------------------
                try {
                    slackSend channel: '#jenkins-alerts', 
                              color: 'danger', 
                              message: "🚨 CRITICAL FAILURE: Job '${env.JOB_NAME}' [Build #${env.BUILD_NUMBER}] failed!"
                } catch (Exception slackError) {
                    echo "❌ Slack step crashed with error: ${slackError.message}"
                }
            }
        }

        unstable {
            script {
                echo "⚠️ Build marked as Unstable."
            }
        }
    }
}
