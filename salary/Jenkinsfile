pipeline {
    agent any

    environment {
        PATH = "/usr/share/maven/bin:$PATH"
    }

    options {
        timeout(time: 15, unit: 'MINUTES')
        ansiColor('xterm')
    }

    stages {
        stage('Initialize & Clean') {
            steps {
                echo "🚀 Initializing Local Testing Environment..."
                sh 'java -version'
                sh 'mvn -version'
                
                // FIXED: Wrapped inside dir() to execute inside the correct directory
                dir('salary') {
                    sh 'mvn clean'
                }
            }
        }

        stage('Continuous Testing (Parallel)') {
            parallel {
                stage('Unit Testing') {
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            echo "🧪 Executing Core Application Tests..."
                            dir('salary') {
                                sh 'mvn test'
                            }
                        }
                    }
                    post {
                        always {
                            dir('salary') {
                                junit testResults: '**/target/surefire-reports/*.xml', allowEmptyResults: true
                            }
                        }
                    }
                }
                
                stage('Smoke Checks') {
                    steps {
                        echo "🔍 Running validation compilation check..."
                        dir('salary') {
                            sh 'mvn compile'
                        }
                    }
                }
            }
        }

        stage('Code Coverage Verification') {
            steps {
                echo "📊 Parsing JaCoCo execution data maps..."
                dir('salary') {
                    jacoco(
                        execPattern: '**/target/*.exec',
                        classPattern: '**/target/classes',
                        sourcePattern: '**/src/main/java',
                        instructionCoverage: '80', 
                        linesCoverage: '80'
                    )
                }
            }
        }

        stage('Generate Site Reports') {
            steps {
                echo "📄 Formatting HTML static test documents..."
                dir('salary') {
                    sh 'mvn site'
                    sh 'mkdir -p target/assignment-reports && cp -r target/site/jacoco/* target/assignment-reports/ || true'
                }
            }
        }
    }

    post {
        always {
            echo "📦 Archiving test report bundles to Jenkins Dashboard..."
            // Looks for the reports folder we isolated inside the salary workspace sub-path
            archiveArtifacts artifacts: 'salary/target/assignment-reports/**', allowEmptyArchive: true
        }
    }
}
