pipeline {
    agent any
    
    tools {
        maven '3.8.7' 
        jdk 'Java 21' // Must match the name exactly as defined in Manage Jenkins -> Tools
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Compile') {
            steps {
                dir('salary') {
                    withEnv(["JAVA_HOME=${tool 'Java 21'}", "PATH+MAVEN=${tool '3.8.7'}/bin"]) {
                        sh 'mvn clean compile'
                    }
                }
            }
        }

        stage('Run Tests') {
            parallel {
                stage('Unit Tests') {
                    steps {
                        dir('salary') {
                            catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                                withEnv(["JAVA_HOME=${tool 'Java 21'}", "PATH+MAVEN=${tool '3.8.7'}/bin"]) {
                                    sh 'mvn test -DskipTests'
                                }
                            }
                        }
                    }
                }
                stage('Integration & E2E Tests') {
                    steps {
                        dir('salary') {
                            catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                                withEnv(["JAVA_HOME=${tool 'Java 21'}", "PATH+MAVEN=${tool '3.8.7'}/bin"]) {
                                    sh 'mvn verify -DskipTests'
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            // 1. Publish test results via JUnit Publisher
            junit allowEmptyResults: true, testResults: 'salary/target/surefire-reports/*.xml,salary/target/failsafe-reports/*.xml'
            
            // 2. Publish JaCoCo coverage using the modern Coverage Plugin
            recordCoverage(
                tools: [[parser: 'JACOCO', pattern: 'salary/target/site/jacoco/jacoco.xml']],
                sourceCodeRetention: 'EVERY_BUILD'
            )
            
            // 3. Archive test artifacts (XML reports, HTML reports)
            // Note: Hamne bas problematic target/*.pdf ko yahan se hata diya hai
            archiveArtifacts artifacts: 'salary/target/site/jacoco/**', allowEmptyArchive: true
        }
        failure {
            echo "Pipeline failed. Check test thresholds or compilation errors."
        }
    }
}
