pipeline {
    agent any
    
    tools {
        maven '3.8.7' 
        jdk 'Java 21' 
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Compile') {
            steps {
                sh 'mvn clean compile'
            }
        }

        // To run things in parallel in Declarative, the stage itself contains sub-stages
        stage('Run Tests') {
            parallel {
                stage('Unit Tests') {
                    steps {
                        // catchError is placed inside the specific parallel execution step
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn test'
                        }
                    }
                }
                stage('Integration & E2E Tests') {
                    steps {
                        catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                            sh 'mvn verify -DskipUTs=true'
                        }
                    }
                }
            }
        }

        stage('Generate PDF Reports') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                    echo "Generating PDF test reports..."
                    sh 'mvn pdf:pdf' 
                }
            }
        }
    }

    post {
        always {
            // 1. Publish test results via JUnit Publisher
            junit allowEmptyResults: true, testResults: '**/target/surefire-reports/*.xml,**/target/failsafe-reports/*.xml'
            
            // 2. Publish JaCoCo coverage using the modern Coverage Plugin
            recordCoverage(
                tools: [[parser: 'JACOCO', pattern: '**/target/site/jacoco/jacoco.xml']],
                sourceCodeRetention: 'EVERY_BUILD'
            )
            
            // 3. Archive test artifacts (XML reports, HTML reports, and generated PDFs)
            archiveArtifacts artifacts: '**/target/*.pdf, **/target/site/jacoco/**', allowEmptyArchive: true
        }
        failure {
            echo "Pipeline failed. Check test thresholds or compilation errors."
        }
    }
}
